# MasterBrain — environment configuration (copy to .env and edit).
# The .env file is read by docker compose. Never commit your real .env.

# --- SACRED persistent vault -------------------------------------------------
# Host path bind-mounted to /data inside the container. This is the durable
# memory; the container is replaceable, this path is not.
#   Local dev (Windows/Mac/Linux): ./        (mounts the repo/vault root)
#   Unraid:                        /mnt/user/appdata/masterbrain
MASTERBRAIN_VAULT_HOST_PATH=./

# --- Image / container naming ------------------------------------------------
MASTERBRAIN_IMAGE=masterbrain:latest
MASTERBRAIN_CONTAINER_NAME=masterbrain

# --- API (optional, lightweight FastAPI) -------------------------------------
# The API always listens on 8077 inside the container. This is the HOST port
# published to reach it. Set to a free port on your Unraid box.
#
# SECURITY: the API has NO AUTH. Keep it LAN-only — never port-forward or
# reverse-proxy it to the internet. To bind to a specific host interface,
# prefix an IP:   MASTERBRAIN_API_PORT=192.168.1.50:8077   (LAN interface)
#                 MASTERBRAIN_API_PORT=127.0.0.1:8077      (host-only)
MASTERBRAIN_API_PORT=8077

# --- System ------------------------------------------------------------------
TZ=UTC

# --- Unraid user/group mapping (NOT YET WIRED) -------------------------------
# The MVP image runs as root, so files written to /data are root-owned. On a
# typical Unraid appdata share this is fine and stays editable. PUID/PGID are
# documented here for a FUTURE hardening pass (an entrypoint that drops to a
# mapped user); they are not applied by the current compose/Dockerfile yet.
# PUID=99
# PGID=100
